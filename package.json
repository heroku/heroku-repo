{
  "name": "@heroku-cli/plugin-heroku-repo",
  "description": "Heroku CLI plugin to manipulate the repo",
  "version": "3.0.0",
  "author": "Heroku",
  "type": "module",
  "bugs": {
    "url": "https://github.com/heroku/heroku-repo/issues"
  },
  "dependencies": {
    "@heroku-cli/command": "~13.0.0",
    "@heroku-cli/notifications": "^1.2.7",
    "@heroku/heroku-cli-util": "10.8.0",
    "@heroku/http-call": "^5.4.0",
    "@oclif/core": "^4.3.0",
    "bytes": "^3.1.2",
    "debug": "^4.4.0",
    "smooth-progress": "^1.1.0",
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "@heroku-cli/schema": "^2.0.0",
    "@heroku-cli/test-utils": "^0.2.0",
    "@types/bytes": "^3.1.4",
    "@types/debug": "^4.1.12",
    "@types/node": "^26.1.1",
    "@types/tar": "^6.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10",
    "eslint-config-oclif": "^6.0.144",
    "nock": "^14.0.0",
    "oclif": "^4.23.14",
    "strip-ansi": "^7",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">= 20"
  },
  "homepage": "https://github.com/heroku/heroku-repo",
  "keywords": [
    "heroku-plugin",
    "oclif"
  ],
  "files": [
    "/dist",
    "/oclif.manifest.json"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "oclif": {
    "commands": "./dist/commands",
    "bin": "heroku",
    "topics": {
      "slugs": {
        "description": "Heroku CLI plugin to manipulate the repo"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/heroku-repo.git"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -b && oclif manifest && oclif readme",
    "lint": "eslint .",
    "postpack": "rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "npm run build",
    "test": "vitest run --coverage",
    "version": "oclif readme && git add README.md"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
